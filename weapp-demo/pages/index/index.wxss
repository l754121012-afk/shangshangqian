page {
  background: #180504;
}

.app {
  min-height: 100vh;
  padding: 24rpx 28rpx 150rpx;
  background:
    radial-gradient(600rpx 420rpx at 75% -10%, rgba(255,209,102,.24), transparent 62%),
    radial-gradient(500rpx 420rpx at -12% 20%, rgba(197,31,26,.22), transparent 64%),
    linear-gradient(180deg, #300b07 0%, #170504 58%, #080201 100%);
  color: #fff4df;
  box-sizing: border-box;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0 20rpx;
}

.brand-sub {
  font-size: 20rpx;
  color: #ffd166;
  letter-spacing: 4rpx;
}

.brand {
  margin-top: 6rpx;
  font-size: 42rpx;
  font-family: Georgia, serif;
  font-weight: 700;
}

.streak {
  min-width: 112rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid rgba(255,209,102,.24);
  border-radius: 28rpx;
  background: rgba(255,209,102,.08);
  text-align: center;
}

.streak-num {
  display: block;
  color: #ffd166;
  font-size: 38rpx;
  font-family: Georgia, serif;
  line-height: 1;
}

.streak-label {
  color: #e6bd82;
  font-size: 20rpx;
}

.page {
  animation: pageIn .2s ease-out;
}

@keyframes pageIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: none; }
}

.panel {
  border: 1rpx solid rgba(255,209,102,.24);
  border-radius: 44rpx;
  background: linear-gradient(145deg, rgba(255,209,102,.10), rgba(197,31,26,.10));
  padding: 30rpx;
  box-shadow: 0 28rpx 70rpx rgba(0,0,0,.25);
}

.title {
  margin: 18rpx 0 8rpx;
  font-size: 56rpx;
  line-height: 1.08;
  font-family: Georgia, serif;
  font-weight: 700;
}

.title text {
  color: #ffd166;
  font-style: italic;
  font-weight: 400;
}

.hint {
  color: #e6bd82;
  font-size: 25rpx;
  line-height: 1.65;
}

.luck-axis {
  margin: 16rpx auto 0;
  max-width: 470rpx;
  opacity: .65;
}

.axis-line {
  position: relative;
  height: 34rpx;
  margin: 0 16rpx;
  border-bottom: 1rpx solid rgba(230,189,130,.16);
  overflow: hidden;
}

.axis-line::after {
  content: "";
  position: absolute;
  left: -42%;
  bottom: 0;
  width: 42%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255,209,102,.36), transparent);
  opacity: 0;
}

.luck-axis.rolling .axis-line::after {
  opacity: 1;
  animation: axisSweep .9s ease-in-out infinite;
}

@keyframes axisSweep {
  to { transform: translateX(340%); }
}

.axis-mark {
  position: absolute;
  bottom: -1rpx;
  width: 34rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: rgba(255,209,102,.28);
  transform: translateX(-50%);
  transition: left .55s cubic-bezier(.2,.9,.18,1.05);
}

.luck-axis.rolling .axis-mark {
  opacity: .16;
}

.axis-labels {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  margin-top: 10rpx;
  color: rgba(230,189,130,.36);
  font-size: 22rpx;
  text-align: center;
}

.axis-labels .hot {
  color: rgba(255,209,102,.42);
}

.pre-note,
.quota {
  margin-top: 10rpx;
  color: rgba(230,189,130,.34);
  font-size: 21rpx;
  text-align: center;
}

.quota {
  color: rgba(230,189,130,.48);
}

.deck {
  min-height: 690rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.aura {
  position: absolute;
  width: 610rpx;
  height: 610rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,209,102,.30), transparent 42%), conic-gradient(from 0deg, transparent, rgba(255,209,102,.15), transparent, rgba(255,122,47,.22), transparent);
  filter: blur(14rpx);
  animation: spin 10s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.card {
  position: relative;
  width: 440rpx;
  min-height: 610rpx;
  border-radius: 48rpx;
  padding: 42rpx 36rpx;
  color: #48160c;
  background: radial-gradient(320rpx 300rpx at 100% 0%, rgba(255,255,255,.45), transparent 70%), linear-gradient(160deg, #fff0c4, #f0b34d);
  border: 1rpx solid rgba(255,232,154,.9);
  box-shadow: 0 38rpx 100rpx rgba(0,0,0,.42), 0 0 60rpx rgba(255,209,102,.34);
  overflow: hidden;
  z-index: 2;
  box-sizing: border-box;
}

.card.low {
  background: linear-gradient(160deg, #e9d9bc, #aa7650);
}

.card.negative {
  background: linear-gradient(160deg, #30282a, #120c0e);
  color: #cbb5a9;
  border-color: rgba(255,255,255,.10);
}

.rarity {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: rgba(72,22,12,.62);
}

.card.negative .rarity {
  color: rgba(255,244,223,.45);
}

.seal {
  position: absolute;
  top: 42rpx;
  right: 38rpx;
  width: 90rpx;
  height: 104rpx;
  border-radius: 14rpx;
  background: #c51f1a;
  color: #fff7e8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  transform: rotate(5deg);
}

.seal text:first-child {
  font-family: Georgia, serif;
  font-size: 38rpx;
  line-height: 1;
}

.seal-sub {
  font-size: 20rpx;
}

.kw {
  margin-top: 50rpx;
  font-family: Georgia, serif;
  font-size: 78rpx;
  line-height: 1.02;
  font-weight: 800;
}

.txt {
  margin-top: 26rpx;
  font-family: Georgia, serif;
  font-size: 29rpx;
  line-height: 1.58;
  color: rgba(72,22,12,.88);
}

.card.negative .txt {
  color: rgba(255,244,223,.72);
}

.pills {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 28rpx;
}

.pill {
  border: 1rpx solid rgba(72,22,12,.20);
  border-radius: 24rpx;
  background: rgba(255,255,255,.15);
  padding: 18rpx 14rpx;
  font-size: 24rpx;
}

.pill text {
  display: block;
  color: #c51f1a;
  font-family: Georgia, serif;
  font-size: 30rpx;
  margin-bottom: 5rpx;
}

.micro {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #6a1d13, #b55a20);
  color: #fff6dd;
  font-size: 25rpx;
  line-height: 1.55;
}

.micro text {
  display: block;
  color: #ffd166;
  font-weight: 700;
}

.flames {
  position: absolute;
  inset: 80rpx 65rpx auto;
  height: 460rpx;
  z-index: 5;
  display: none;
}

.rare .flames {
  display: block;
}

.flame {
  position: absolute;
  width: 54rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #fff3a0, #ff7a2f 58%, transparent);
  filter: drop-shadow(0 0 20rpx rgba(255,122,47,.85));
  animation: flicker .9s ease-in-out infinite alternate;
}







@keyframes flicker {
  from { transform: scale(.9); opacity: .7; }
  to { transform: scale(1.12); opacity: 1; }
}

.btn {
  width: 100%;
  min-height: 88rpx;
  border-radius: 999rpx;
  padding: 0 30rpx;
  color: #3a0f08;
  background: linear-gradient(180deg, #ffe08a, #d99235);
  font-weight: 800;
  font-size: 29rpx;
  line-height: 1.25;
  box-shadow: 0 18rpx 44rpx rgba(255,209,102,.26);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  white-space: normal;
}

.btn.sub {
  color: #fff4df;
  background: rgba(255,255,255,.055);
  border: 1rpx solid rgba(255,209,102,.24);
  box-shadow: none;
}

.btn.danger {
  color: #fff4df;
  background: linear-gradient(180deg, #682421, #321211);
}

.btn.mini {
  margin-top: 18rpx;
  min-height: 72rpx;
  padding: 0 20rpx;
  font-size: 25rpx;
}

.primary-action {
  margin-top: 0;
}

.actions {
  width: 100%;
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  overflow: hidden;
}

.row {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 0;
  box-sizing: border-box;
}

.action-btn {
  width: auto;
  min-width: 0;
  max-width: 100%;
  min-height: 86rpx;
  padding: 0 14rpx;
  font-size: 26rpx;
  text-align: center;
}

.full-action {
  width: 100%;
  min-height: 86rpx;
}

.msg {
  margin-top: 22rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255,209,102,.24);
  background: rgba(255,209,102,.08);
  padding: 24rpx;
  color: #e6bd82;
  font-size: 25rpx;
  line-height: 1.65;
}

.msg text {
  display: block;
  color: #ffd166;
  font-weight: 700;
}

.album {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.mini-card {
  position: relative;
  aspect-ratio: .72 / 1;
  border-radius: 28rpx;
  padding: 16rpx 12rpx;
  background: linear-gradient(160deg, #fff0c4, #d99235);
  color: #48160c;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  font-family: Georgia, serif;
  box-shadow: 0 18rpx 42rpx rgba(0,0,0,.25);
}

.mini-card.lock {
  color: rgba(255,244,223,.34);
  background: rgba(255,255,255,.05);
  border: 1rpx solid rgba(255,209,102,.14);
}

.mini-card.ssr {
  box-shadow: 0 0 42rpx rgba(255,209,102,.48), 0 18rpx 42rpx rgba(0,0,0,.25);
}

.mini-r {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  font-size: 16rpx;
}

.set {
  margin-top: 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255,209,102,.24);
  background: rgba(197,31,26,.16);
  padding: 24rpx;
  color: #e6bd82;
  font-size: 25rpx;
  line-height: 1.65;
}

.friend-list {
  margin-top: 24rpx;
}

.friend {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255,209,102,.24);
  background: rgba(255,209,102,.08);
  margin-bottom: 16rpx;
}

.rank {
  width: 48rpx;
  color: #ffd166;
  font-family: Georgia, serif;
  font-size: 44rpx;
  text-align: center;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd166, #c51f1a);
}

.friend-meta {
  flex: 1;
}

.friend-meta view {
  font-size: 28rpx;
}

.friend-meta text {
  color: #e6bd82;
  font-size: 23rpx;
}

.pool-panel {
  margin-top: 24rpx;
}

.pool {
  width: 340rpx;
  height: 340rpx;
  margin: 20rpx auto;
  border-radius: 50%;
  background: radial-gradient(circle at 45% 38%, rgba(255,232,154,.96), rgba(255,122,47,.55) 46%, rgba(197,31,26,.18) 70%, transparent 72%);
  box-shadow: 0 0 70rpx rgba(255,209,102,.42);
  position: relative;
}

.pool view {
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd166, #c51f1a);
}

.pool view:nth-child(1){left:55rpx;top:75rpx}
.pool view:nth-child(2){right:55rpx;top:62rpx}
.pool view:nth-child(3){left:145rpx;bottom:42rpx}
.pool view:nth-child(4){right:95rpx;bottom:118rpx}
.pool view:nth-child(5){left:65rpx;bottom:104rpx}

.center {
  text-align: center;
}

.share-card {
  margin-top: 24rpx;
  border-radius: 42rpx;
  color: #48160c;
  background: linear-gradient(160deg, #fff0c4, #f0b34d);
  padding: 34rpx;
  box-shadow: 0 38rpx 100rpx rgba(0,0,0,.42);
}

.share-k {
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.share-title {
  margin: 18rpx 0;
  font-family: Georgia, serif;
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 800;
}

.share-text {
  color: rgba(72,22,12,.82);
  line-height: 1.6;
}

.reset {
  margin-top: 16rpx;
}

.ad-overlay {
  position: fixed;
  z-index: 50;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10,2,1,.76);
  backdrop-filter: blur(18rpx);
  padding: 44rpx;
}

.ad-card {
  width: 100%;
  border: 1rpx solid rgba(255,209,102,.32);
  border-radius: 46rpx;
  background: linear-gradient(160deg, rgba(58,18,10,.96), rgba(20,5,4,.96));
  padding: 36rpx;
  text-align: center;
}

.ad-tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255,209,102,.24);
  color: rgba(230,189,130,.72);
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.ad-title {
  margin: 24rpx 0 10rpx;
  font-family: Georgia, serif;
  font-size: 46rpx;
  color: #ffd166;
}

.ad-copy {
  color: #e6bd82;
  font-size: 25rpx;
  line-height: 1.6;
}

.ad-progress {
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.08);
  overflow: hidden;
  margin-top: 28rpx;
}

.ad-progress view {
  height: 100%;
  width: 0;
  background: linear-gradient(90deg, #ffd166, #f07d22);
  animation: adProgress 2.6s linear forwards;
}

@keyframes adProgress {
  to { width: 100%; }
}

.ad-count {
  margin-top: 18rpx;
  color: rgba(230,189,130,.52);
  font-size: 22rpx;
}

.tabs {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 24rpx 24rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  background: rgba(24,5,4,.90);
  border-top: 1rpx solid rgba(255,209,102,.24);
}

.tab {
  text-align: center;
  color: #e6bd82;
  border-radius: 24rpx;
  padding: 12rpx 8rpx;
  font-size: 34rpx;
}

.tab text {
  display: block;
  font-size: 20rpx;
  margin-top: 2rpx;
}

.tab.on {
  color: #ffd166;
  background: rgba(255,209,102,.09);
}

/* ===== 牌册差异化样式 v17 ===== */
.album-v2{display:grid;grid-template-columns:repeat(2,1fr);gap:20rpx;margin-top:40rpx}
.album-card{position:relative;border-radius:36rpx;overflow:hidden;box-shadow:0 12rpx 36rpx rgba(0,0,0,.2);display:flex;flex-direction:column;font-family:Georgia,serif;min-height:380rpx}
.album-card-inner{flex:1;display:flex;flex-direction:column;justify-content:space-between;position:relative;z-index:2}
.ac-top{position:relative;min-height:72rpx}
.ac-grade{position:absolute;top:16rpx;left:16rpx;font-size:18rpx;font-weight:700;letter-spacing:2rpx;padding:4rpx 14rpx;border-radius:6px;z-index:3}
.ac-seal{position:absolute;top:16rpx;right:16rpx;width:52rpx;height:52rpx;border-radius:6rpx;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-family:Georgia,serif;transform:rotate(3deg);z-index:3;font-weight:800}
.ac-body{flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:20rpx 20rpx 12rpx;gap:10rpx}
.ac-name{font-size:30rpx;font-weight:800;text-align:center;line-height:1.1}
.ac-text{font-size:20rpx;text-align:center;line-height:1.35;min-height:48rpx}
.ac-bottom{padding:16rpx 20rpx 20rpx;border-top:1px solid transparent}
.ac-action{font-size:18rpx;text-align:center;font-style:italic;opacity:.7}

/* 大吉签 */
.ac-daji{background:radial-gradient(circle at 50% 0%,#e84a2a,#c83018 35%,#a01808 70%);border:5rpx solid #f0d0a0;color:#f0d0a0;animation:dajiGlow 3s ease-in-out infinite alternate;box-shadow:0 12rpx 36rpx rgba(0,0,0,.25),0 0 24rpx rgba(232,74,42,.3),inset 0 0 40rpx rgba(0,0,0,.1)}
@keyframes dajiGlow{0%{box-shadow:0 12rpx 36rpx rgba(0,0,0,.25),0 0 24rpx rgba(232,74,42,.25)}100%{box-shadow:0 12rpx 36rpx rgba(0,0,0,.25),0 0 40rpx rgba(232,74,42,.4),0 0 72rpx rgba(255,209,102,.12)}}
.ac-daji::before{content:"";position:absolute;inset:10rpx;border:2rpx solid rgba(240,208,160,.35);border-radius:24rpx;pointer-events:none;z-index:1}
.ac-daji .ac-grade{background:#f0d0a0;color:#b5180a;box-shadow:0 4rpx 10rpx rgba(0,0,0,.25)}
.ac-daji .ac-seal{background:#c01818;color:#fff0e0;box-shadow:0 6rpx 16rpx rgba(0,0,0,.35),inset 0 2rpx 0 rgba(255,255,255,.15);border:2rpx solid rgba(255,255,255,.1);transform:rotate(5deg)}
.ac-daji .ac-name{font-size:36rpx;color:#f0d0a0;filter:drop-shadow(0 2rpx 6rpx rgba(0,0,0,.4));letter-spacing:4rpx}
.ac-daji .ac-text{color:rgba(240,208,160,.85);font-weight:500}
.ac-daji .ac-bottom{border-color:rgba(240,208,160,.2)}
.ac-daji .ac-action{color:rgba(240,208,160,.6);font-weight:600}
.ac-daji .ac-bottom-deco{position:absolute;bottom:0;left:0;right:0;height:56rpx;background:linear-gradient(180deg,transparent,rgba(80,10,4,.5));border-radius:0 0 36rpx 36rpx;pointer-events:none;z-index:1}
/* 大吉签扫光 */
.ac-daji .ac-sweep{position:absolute;top:0;left:-60%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,209,102,.18),rgba(255,240,180,.25),rgba(255,209,102,.18),transparent);z-index:1;pointer-events:none;animation:acSweep 3.5s ease-in-out infinite}
@keyframes acSweep{0%{left:-60%}45%{left:100%}100%{left:100%}}
/* 大吉签旋转光晕 */
.ac-daji .ac-glow-orbit{position:absolute;top:50%;left:50%;width:220%;height:220%;transform:translate(-50%,-50%);pointer-events:none;z-index:0;animation:acOrbit 6s linear infinite;border-radius:50%}
.ac-daji .ac-glow-orbit .ac-g1{position:absolute;top:0;left:50%;transform:translateX(-50%);width:40%;height:16%;background:radial-gradient(ellipse,rgba(255,209,102,.35),transparent 70%);filter:blur(16rpx)}
.ac-daji .ac-glow-orbit .ac-g2{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:30%;height:12%;background:radial-gradient(ellipse,rgba(255,180,60,.25),transparent 70%);filter:blur(12rpx)}
@keyframes acOrbit{to{transform:translate(-50%,-50%) rotate(360deg)}}
/* 大吉签底纹 */
.ac-daji-texture{position:absolute;inset:0;border-radius:36rpx;overflow:hidden;pointer-events:none;z-index:1}
.ac-daji-texture .ac-flame-bar{position:absolute;bottom:68rpx;left:28rpx;display:flex;align-items:flex-end;gap:4rpx;opacity:.08}
.ac-daji-texture .ac-flame-bar .afb1{width:10rpx;height:36rpx;background:#ffd166}
.ac-daji-texture .ac-flame-bar .afb2{width:14rpx;height:52rpx;background:#ffd166}
.ac-daji-texture .ac-flame-bar .afb3{width:10rpx;height:36rpx;background:#ffd166}
.ac-daji-texture .ac-star{position:absolute;bottom:76rpx;right:44rpx;width:64rpx;height:64rpx;opacity:.08}
.ac-daji-texture .ac-star .asc{width:12rpx;height:12rpx;background:#ffd166;border-radius:50%;position:absolute;top:26rpx;left:26rpx}
.ac-daji-texture .ac-star .ash{width:64rpx;height:2rpx;background:#ffd166;position:absolute;top:30rpx;left:0}
.ac-daji-texture .ac-star .asv{width:2rpx;height:64rpx;background:#ffd166;position:absolute;top:0;left:30rpx}

/* 上上签 */
.ac-shangshang{background:linear-gradient(180deg,#faf0d0,#f0e0b0);border:4rpx solid #e0c880;color:#4a2818;box-shadow:0 12rpx 36rpx rgba(0,0,0,.15)}
.ac-shangshang::before{content:"";position:absolute;inset:8rpx;border:2rpx solid rgba(200,170,100,.3);border-radius:28rpx;pointer-events:none;z-index:1}
.ac-shangshang .ac-grade{background:#e0c880;color:#4a2818;font-weight:800;box-shadow:0 2rpx 8rpx rgba(0,0,0,.1)}
.ac-shangshang .ac-seal{background:#c01818;color:#fff0e0;box-shadow:0 4rpx 12rpx rgba(0,0,0,.2),inset 0 2rpx 0 rgba(255,255,255,.1);border:2rpx solid rgba(255,255,255,.1)}
.ac-shangshang .ac-name{font-size:32rpx;color:#4a2818;letter-spacing:2rpx}
.ac-shangshang .ac-text{color:#6a4030;font-weight:500}
.ac-shangshang .ac-bottom{border-color:rgba(200,170,100,.25)}
.ac-shangshang .ac-action{color:rgba(100,70,40,.5)}
.ac-shangshang .ac-bottom-deco{position:absolute;bottom:0;left:0;right:0;height:48rpx;background:linear-gradient(180deg,transparent,rgba(160,130,70,.3));border-radius:0 0 36rpx 36rpx;pointer-events:none;z-index:1}
/* 上上签底纹 */
.ac-ss-texture{position:absolute;inset:0;border-radius:36rpx;overflow:hidden;pointer-events:none;z-index:1}
.ac-ss-texture .ac-arc{position:absolute;width:112rpx;height:44rpx;border-top:2rpx solid #b89650;border-radius:50%;opacity:.1}
.ac-ss-texture .ac-arc1{bottom:60rpx;left:16rpx}
.ac-ss-texture .ac-arc2{bottom:72rpx;left:68rpx}
.ac-ss-texture .ac-arc3{bottom:56rpx;right:20rpx}

/* 上签 */
.ac-shang{background:linear-gradient(180deg,#f5e8d0,#dcc090);border:4rpx solid rgba(200,170,110,.5);color:#5a4030;box-shadow:0 12rpx 32rpx rgba(0,0,0,.12)}
.ac-shang::before{content:"";position:absolute;inset:8rpx;border:2rpx solid rgba(180,150,90,.25);border-radius:28rpx;pointer-events:none;z-index:1}
.ac-shang .ac-grade{background:rgba(200,170,110,.3);color:#5a4030;font-weight:700}
.ac-shang .ac-seal{background:#b85030;color:#fff0e0;box-shadow:0 2rpx 8rpx rgba(0,0,0,.15);border:2rpx solid rgba(255,255,255,.1)}
.ac-shang .ac-name{font-size:30rpx;color:#4a3020}
.ac-shang .ac-text{color:#6a5040}
.ac-shang .ac-bottom{border-color:rgba(180,150,90,.2)}
.ac-shang .ac-action{color:rgba(120,90,60,.5)}
.ac-shang .ac-bottom-deco{position:absolute;bottom:0;left:0;right:0;height:48rpx;background:linear-gradient(180deg,transparent,rgba(160,130,80,.25));border-radius:0 0 36rpx 36rpx;pointer-events:none;z-index:1}

/* 平签 */
.ac-ping{background:linear-gradient(180deg,#c8a060,#8a6838);border:3rpx solid rgba(180,150,90,.45);color:#fff8f0;box-shadow:0 12rpx 32rpx rgba(0,0,0,.1)}
.ac-ping::before{content:"";position:absolute;inset:8rpx;border:2rpx solid rgba(220,190,140,.2);border-radius:28rpx;pointer-events:none;z-index:1}
.ac-ping .ac-grade{background:rgba(220,190,140,.25);color:#fff8f0;font-weight:600}
.ac-ping .ac-seal{background:rgba(180,70,50,.85);color:#fff0e0;box-shadow:0 2rpx 6rpx rgba(0,0,0,.1);border:2rpx solid rgba(255,255,255,.1)}
.ac-ping .ac-name{font-size:28rpx;color:#fff8f0}
.ac-ping .ac-text{color:rgba(255,248,240,.8)}
.ac-ping .ac-bottom{border-color:rgba(220,190,140,.2)}
.ac-ping .ac-action{color:rgba(255,248,240,.55)}
.ac-ping .ac-bottom-deco{position:absolute;bottom:0;left:0;right:0;height:40rpx;background:linear-gradient(180deg,transparent,rgba(80,60,30,.35));border-radius:0 0 36rpx 36rpx;pointer-events:none;z-index:1}

/* 未收集 */


/* 牌册统计 */
.album-stats{display:flex;gap:16rpx;margin-top:32rpx}
.album-stat{flex:1;border-radius:28rpx;border:2rpx solid rgba(255,209,102,.18);background:rgba(255,209,102,.06);padding:20rpx;text-align:center}
.album-stat b{display:block;font-family:Georgia,serif;font-size:40rpx;color:#ffd166}
.album-stat span{font-size:18rpx;color:#e6bd82}

/* ===== 漂流签样式 ===== */
.drift-list{margin-top:32rpx;display:flex;flex-direction:column;gap:24rpx}
.drift-item{position:relative;border-radius:36rpx;padding:28rpx 32rpx;background:linear-gradient(180deg,#1e0e0c,#140807);border:2rpx solid rgba(255,209,102,.14);box-shadow:0 8rpx 28rpx rgba(0,0,0,.2)}
.drift-meta{display:flex;align-items:center;gap:16rpx;margin-bottom:16rpx}
.drift-avatar{width:56rpx;height:56rpx;border-radius:50%;background:linear-gradient(135deg,#ffd166,#c51f1a);display:flex;align-items:center;justify-content:center;font-size:22rpx;color:#fff;font-weight:700}
.drift-name{font-size:24rpx;color:#e6bd82;font-weight:600}
.drift-tag{font-size:18rpx;color:#ffd166;background:rgba(255,209,102,.1);padding:2rpx 12rpx;border-radius:6rpx;margin-left:auto}
.drift-quote{font-size:24rpx;color:rgba(255,244,223,.75);line-height:1.55;margin-bottom:16rpx}
.drift-from{font-size:20rpx;color:rgba(230,189,130,.45);font-style:italic}
.drift-actions{display:flex;gap:16rpx;margin-top:20rpx}
.drift-btn{flex:1;padding:14rpx 0;border-radius:20rpx;border:2rpx solid rgba(255,209,102,.2);background:rgba(255,209,102,.06);color:#e6bd82;font-size:22rpx;text-align:center}
.drift-btn.primary{background:linear-gradient(180deg,#ffe08a,#d99235);color:#3a0f08;border:none;font-weight:700}

/* 漂流签tab切换 */
.drift-tabs{display:flex;gap:12rpx;margin-top:24rpx}
.drift-tab{flex:1;padding:16rpx 0;border-radius:20rpx;border:2rpx solid rgba(255,209,102,.14);background:rgba(255,209,102,.04);color:#e6bd82;font-size:22rpx;text-align:center}
.drift-tab.on{background:rgba(255,209,102,.1);color:#ffd166;border-color:rgba(255,209,102,.3);font-weight:700}

/* 好友申请弹窗 */
.drift-modal-overlay{position:absolute;inset:0;background:rgba(10,2,1,.82);display:flex;align-items:center;justify-content:center;padding:40rpx;z-index:50}
.drift-modal{width:100%;border-radius:48rpx;border:2rpx solid rgba(255,209,102,.22);background:linear-gradient(160deg,#2a1512,#180a08);padding:48rpx;text-align:center;box-shadow:0 48rpx 120rpx rgba(0,0,0,.4)}
.drift-modal-avatar{width:112rpx;height:112rpx;border-radius:50%;background:linear-gradient(135deg,#ffd166,#c51f1a);margin:0 auto 24rpx;display:flex;align-items:center;justify-content:center;font-size:44rpx;color:#fff;font-weight:800}
.drift-modal-title{font-family:Georgia,serif;font-size:40rpx;color:#ffd166;margin-bottom:8rpx}
.drift-modal-sub{font-size:24rpx;color:#e6bd82;margin-bottom:28rpx}
.drift-modal-note{font-size:22rpx;color:rgba(230,189,130,.6);line-height:1.5;margin-bottom:32rpx;padding:20rpx;border-radius:20rpx;background:rgba(255,209,102,.06);border:2rpx solid rgba(255,209,102,.1)}
.drift-modal-actions{display:flex;gap:20rpx}
.drift-modal-btn{flex:1;padding:22rpx 0;border-radius:24rpx;border:2rpx solid rgba(255,209,102,.2);background:transparent;color:#e6bd82;font-size:26rpx}
.drift-modal-btn.primary{background:linear-gradient(180deg,#ffe08a,#d99235);color:#3a0f08;border:none;font-weight:700}

/* 漂流签底部送出入口 */
.drift-send-bar{position:absolute;bottom:0;left:0;right:0;padding:24rpx 32rpx;background:rgba(24,5,4,.95);border-top:2rpx solid rgba(255,209,102,.18);display:flex;align-items:center;gap:20rpx}
.drift-send-icon{width:64rpx;height:64rpx;border-radius:50%;background:linear-gradient(135deg,#ffd166,#c51f1a);display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#fff}
.drift-send-info{flex:1}
.drift-send-info b{color:#ffd166;display:block;font-size:26rpx;margin-bottom:4rpx}
.drift-send-info text{color:#e6bd82;font-size:22rpx}
.drift-send-btn{padding:14rpx 28rpx;border-radius:20rpx;border:none;background:linear-gradient(180deg,#ffe08a,#d99235);color:#3a0f08;font-size:22rpx;font-weight:700}

/* 大吉签抽出时扫光+旋转光晕特效 */
.card-sweep-wrap{position:absolute;inset:0;border-radius:48rpx;overflow:hidden;pointer-events:none;z-index:1}
.card-sweep{position:absolute;top:0;left:-60%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,209,102,.18),rgba(255,240,180,.25),rgba(255,209,102,.18),transparent);animation:cardSweep 3.5s ease-in-out infinite}
@keyframes cardSweep{0%{left:-60%}45%{left:100%}100%{left:100%}}
.card-glow-orbit{position:absolute;top:50%;left:50%;width:220%;height:220%;transform:translate(-50%,-50%);pointer-events:none;z-index:0;animation:cardOrbit 6s linear infinite;border-radius:50%}
.card-glow-orbit .cg1{position:absolute;top:0;left:50%;transform:translateX(-50%);width:40%;height:16%;background:radial-gradient(ellipse,rgba(255,209,102,.35),transparent 70%);filter:blur(16rpx)}
.card-glow-orbit .cg2{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:30%;height:12%;background:radial-gradient(ellipse,rgba(255,180,60,.25),transparent 70%);filter:blur(12rpx)}
@keyframes cardOrbit{to{transform:translate(-50%,-50%) rotate(360deg)}}

/* 抽签页大吉签样式 - 和牌册大吉签统一 */
.card.card-daji{background:radial-gradient(circle at 50% 0%,#e84a2a,#c83018 35%,#a01808 70%)!important;border:2.5px solid #f0d0a0!important;color:#f0d0a0!important;box-shadow:0 38rpx 100rpx rgba(0,0,0,.42),0 0 24rpx rgba(232,74,42,.3),inset 0 0 40rpx rgba(0,0,0,.1)!important;animation:drawCardGlow 3s ease-in-out infinite alternate}
@keyframes drawCardGlow{0%{box-shadow:0 38rpx 100rpx rgba(0,0,0,.42),0 0 24rpx rgba(232,74,42,.25)}100%{box-shadow:0 38rpx 100rpx rgba(0,0,0,.42),0 0 40rpx rgba(232,74,42,.4),0 0 72rpx rgba(255,209,102,.12)}}
.card.card-daji::before{content:"";position:absolute;inset:10rpx;border:2rpx solid rgba(240,208,160,.35);border-radius:36rpx;pointer-events:none;z-index:1}
.card.card-daji .rarity{color:rgba(240,208,160,.8)!important}
.card.card-daji .seal{background:#c01818!important;box-shadow:0 6rpx 16rpx rgba(0,0,0,.35),inset 0 2rpx 0 rgba(255,255,255,.15)!important;border:2rpx solid rgba(255,255,255,.1)!important}
.card.card-daji .kw{color:#f0d0a0!important;filter:drop-shadow(0 2rpx 6rpx rgba(0,0,0,.4));letter-spacing:4rpx}
.card.card-daji .txt{color:rgba(240,208,160,.85)!important}
.card.card-daji .pills .pill{border-color:rgba(240,208,160,.25)!important;background:rgba(0,0,0,.1)!important;color:#f0d0a0!important}
.card.card-daji .pills .pill text{color:#ffd166!important}
.card.card-daji .micro{background:linear-gradient(135deg,#6a1d13,#b55a20)!important;color:#fff6dd!important}
.card.card-daji .micro text{color:#ffd166!important}

/* 抽签页上上签样式 */
.card.card-shangshang{background:linear-gradient(180deg,#faf0d0,#f0e0b0)!important;border:2px solid #e0c880!important;color:#4a2818!important}
.card.card-shangshang .rarity{color:rgba(74,40,24,.8)!important}
.card.card-shangshang .seal{background:#c01818!important}
.card.card-shangshang .kw{color:#4a2818!important;letter-spacing:2rpx}
.card.card-shangshang .txt{color:rgba(106,64,48,.88)!important}

/* 比手气卡飞行动画 */
.share-card-flying{animation:cardFlyOut 1s ease-in forwards}
@keyframes cardFlyOut{0%{transform:scale(1);opacity:1}50%{transform:scale(.5) translateY(-100rpx);opacity:.7}100%{transform:scale(.1) translateY(-300rpx);opacity:0}}
/* 好友列表中"我"的高亮 */
.friend-me{background:rgba(255,209,102,.12)!important;border-color:rgba(255,209,102,.35)!important}
.friend-me .friend-meta view{color:#ffd166}

/* 打赏弹窗 */
.support-overlay{position:fixed;z-index:50;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(10,2,1,.82);padding:40rpx}
.support-card{width:100%;border-radius:36rpx;border:2rpx solid rgba(255,209,102,.22);background:linear-gradient(160deg,#2a1512,#180a08);padding:40rpx;text-align:center;box-shadow:0 36rpx 90rpx rgba(0,0,0,.4)}
.support-title{font-family:Georgia,serif;font-size:40rpx;color:#ffd166;margin-bottom:8rpx}
.support-sub{font-size:24rpx;color:#e6bd82;line-height:1.5;margin-bottom:32rpx}
.support-amounts{display:flex;gap:20rpx;justify-content:center;margin-bottom:28rpx}
.support-amount{flex:1;padding:20rpx 0;border-radius:20rpx;border:2rpx solid rgba(255,209,102,.2);background:rgba(255,209,102,.06);text-align:center}
.support-amount.sa-pop{border-color:rgba(255,209,102,.5);background:rgba(255,209,102,.12);position:relative}
.support-amount.sa-pop::after{content:"推荐";position:absolute;top:-16rpx;right:-8rpx;font-size:18rpx;color:#fff;background:#c51f1a;padding:2rpx 10rpx;border-radius:8rpx}
.sa-val{font-family:Georgia,serif;font-size:36rpx;color:#ffd166;display:block;margin-bottom:4rpx}
.sa-label{font-size:20rpx;color:#e6bd82;display:block}
.support-hint{font-size:20rpx;color:rgba(230,189,130,.4);font-style:italic}

/* 问卷入口 */
.survey-entry{display:flex;align-items:center;gap:16rpx;padding:24rpx;border-radius:28rpx;border:2rpx solid rgba(255,209,102,.18);background:rgba(255,209,102,.06);margin-top:24rpx}
.survey-entry-icon{font-size:36rpx}
.survey-entry-info{flex:1}
.survey-entry-info b{display:block;font-size:26rpx;color:#ffd166;margin-bottom:4rpx}
.survey-entry-info text{display:block;font-size:20rpx;color:#e6bd82}
.survey-entry-arrow{font-size:32rpx;color:#e6bd82}

/* 问卷弹窗 */
.survey-overlay{position:fixed;z-index:50;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(10,2,1,.88);padding:32rpx}
.survey-card{width:100%;max-height:85vh;overflow-y:auto;border-radius:36rpx;border:2rpx solid rgba(255,209,102,.22);background:linear-gradient(160deg,#2a1512,#180a08);padding:40rpx}
.survey-header{margin-bottom:32rpx}
.survey-title{font-family:Georgia,serif;font-size:40rpx;color:#ffd166}
.survey-sub{font-size:22rpx;color:#e6bd82;margin-top:8rpx}
.survey-q{margin-bottom:28rpx}
.survey-q-title{font-size:26rpx;color:#fff4df;margin-bottom:16rpx;font-weight:600}
.survey-opts{display:flex;flex-wrap:wrap;gap:12rpx}
.survey-opt{padding:16rpx 24rpx;border-radius:20rpx;border:2rpx solid rgba(255,209,102,.2);background:rgba(255,209,102,.04);color:#e6bd82;font-size:24rpx;transition:all .15s}
.survey-opt.on{background:rgba(255,209,102,.15);border-color:rgba(255,209,102,.5);color:#ffd166;font-weight:600}
.survey-submit{width:100%;padding:24rpx;border-radius:999rpx;border:none;background:linear-gradient(180deg,#ffe08a,#d99235);color:#3a0f08;font-size:28rpx;font-weight:800;text-align:center;margin-top:12rpx}

.survey-input{width:100%;height:72rpx;border:2rpx solid rgba(255,209,102,.2);border-radius:20rpx;background:rgba(255,209,102,.04);color:#e6bd82;font-size:24rpx;padding:0 20rpx;margin-top:12rpx;box-sizing:border-box}
.survey-char-count{text-align:right;font-size:20rpx;color:rgba(230,189,130,.4);margin-top:8rpx}

/* 牌册分组标题 */
.album-section-title{grid-column:1 / -1;font-size:22rpx;color:#e6bd82;letter-spacing:2rpx;margin:8rpx 0 4rpx;padding-left:8rpx;border-left:3rpx solid rgba(255,209,102,.3);line-height:1.4}
.album-section-title text{color:#ffd166;font-weight:700;margin-left:6rpx}

/* 负面签消除输入弹窗 */
.dissolve-overlay{position:fixed;z-index:50;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(10,2,1,.82);padding:40rpx}
.dissolve-card{width:100%;border-radius:36rpx;border:2rpx solid rgba(255,209,102,.22);background:linear-gradient(160deg,#2a1512,#180a08);padding:40rpx;text-align:center;box-shadow:0 36rpx 90rpx rgba(0,0,0,.4)}
.dissolve-title{font-family:Georgia,serif;font-size:40rpx;color:#ffd166;margin-bottom:8rpx}
.dissolve-sub{font-size:24rpx;color:#e6bd82;line-height:1.5;margin-bottom:32rpx}
.dissolve-input{width:100%;height:72rpx;border:2rpx solid rgba(255,209,102,.2);border-radius:20rpx;background:rgba(255,209,102,.04);color:#e6bd82;font-size:24rpx;padding:0 20rpx;margin-bottom:32rpx;box-sizing:border-box;text-align:center}
.dissolve-actions{display:flex;gap:20rpx}
.dissolve-btn{flex:1;padding:22rpx 0;border-radius:24rpx;border:2rpx solid rgba(255,209,102,.2);background:transparent;color:#e6bd82;font-size:26rpx}
.dissolve-btn.primary{background:linear-gradient(180deg,#ffe08a,#d99235);color:#3a0f08;border:none;font-weight:700}

.ac-locked{opacity:.35;position:relative;overflow:hidden}
.ac-locked-mask{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10rpx;background:rgba(10,2,1,.55);z-index:5;border-radius:18rpx}
.ac-locked-icon{font-size:44rpx;color:#ffd166;font-weight:700}
.ac-locked-text{font-size:20rpx;color:#e6bd82;letter-spacing:2rpx}

/* 彩蛋签 */
.ac-egg{background:radial-gradient(circle at 50% 0%,#7c3aed,#5b21b6 35%,#3b0764 70%);border:2.5px solid #d8b4fe;color:#e9d5ff;animation:eggGlow 3s ease-in-out infinite alternate;box-shadow:0 6px 18px rgba(0,0,0,.25),0 0 12px rgba(124,58,237,.3),inset 0 0 20px rgba(0,0,0,.1);position:relative;overflow:hidden}
@keyframes eggGlow{0%{box-shadow:0 6px 18px rgba(0,0,0,.25),0 0 12px rgba(124,58,237,.25)}100%{box-shadow:0 6px 18px rgba(0,0,0,.25),0 0 20px rgba(124,58,237,.4),0 0 36px rgba(216,180,254,.12)}}
.ac-egg::before{content:"";position:absolute;inset:5px;border:1px solid rgba(233,213,255,.35);border-radius:12px;pointer-events:none;z-index:1}
.ac-egg .card-v3-grade{background:#e9d5ff;color:#5b21b6;box-shadow:0 2px 5px rgba(0,0,0,.25);border-radius:3px}
.ac-egg .card-v3-seal{background:#6d28d9;color:#f3e8ff;box-shadow:0 3px 8px rgba(0,0,0,.35),inset 0 1px 0 rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.1);transform:rotate(5deg)}
.ac-egg .card-v3-name{font-size:18px;color:#e9d5ff;filter:drop-shadow(0 1px 3px rgba(0,0,0,.4));letter-spacing:.05em}
.ac-egg .card-v3-text{color:rgba(233,213,255,.85);font-weight:500}
.ac-egg .card-v3-bottom{border-color:rgba(233,213,255,.2)}
.ac-egg .card-v3-action{color:rgba(233,213,255,.6);font-weight:600}
.ac-egg-shine{position:absolute;top:0;left:-60%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(233,213,255,.12),rgba(216,180,254,.18),rgba(233,213,255,.12),transparent);z-index:2;pointer-events:none;animation:eggSweep 3.5s ease-in-out infinite}
@keyframes eggSweep{0%{left:-60%}45%{left:100%}100%{left:100%}}

/* 彩蛋统计标签 */
.album-stat.egg{color:#d8b4fe}
.album-stat.egg b{color:#e9d5ff}
