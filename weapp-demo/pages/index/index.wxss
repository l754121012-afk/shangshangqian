/* ===== 彩蛋签边框主题色流转特效 ===== */
.ac-egg,.card-egg{position:relative}
/* 彩蛋签边框流光特效：用伪元素沿边框移动的光点 */
.ac-egg::after,.card-egg::after{content:"";position:absolute;width:10%;height:4rpx;z-index:5;border-radius:2rpx}
/* 桃花 - 粉色光点沿边框流动 */
.ac-egg-peach::after,.draw-egg-peach::after{background:linear-gradient(90deg,transparent,rgba(255,180,220,.8),rgba(255,150,200,.9),rgba(255,180,220,.8),transparent);box-shadow:0 0 12rpx rgba(255,150,200,.4);animation:flowAll 4s ease-in-out infinite}
/* 金榜 - 金色光点沿边框流动 */
.ac-egg-golden::after,.draw-egg-golden::after{background:linear-gradient(90deg,transparent,rgba(255,220,100,.8),rgba(255,200,50,.9),rgba(255,220,100,.8),transparent);box-shadow:0 0 12rpx rgba(255,200,50,.4);animation:flowAll 4s ease-in-out infinite}
/* 归家 - 蓝色光点沿边框流动 */
.ac-egg-home::after,.draw-egg-home::after{background:linear-gradient(90deg,transparent,rgba(150,200,255,.8),rgba(100,180,255,.9),rgba(150,200,255,.8),transparent);box-shadow:0 0 12rpx rgba(100,180,255,.4);animation:flowAll 4s ease-in-out infinite}
/* 远行 - 青绿光点沿边框流动 */
.ac-egg-travel::after,.draw-egg-travel::after{background:linear-gradient(90deg,transparent,rgba(150,230,220,.8),rgba(128,220,200,.9),rgba(150,230,220,.8),transparent);box-shadow:0 0 12rpx rgba(128,220,200,.4);animation:flowAll 4s ease-in-out infinite}
@keyframes flowAll{
  0%{top:0;left:-10%;width:10%;height:4rpx}
  22%{top:0;left:110%;width:10%;height:4rpx}
  23%{top:-10%;left:calc(100% - 4rpx);width:4rpx;height:10%}
  47%{top:110%;left:calc(100% - 4rpx);width:4rpx;height:10%}
  48%{top:calc(100% - 4rpx);left:110%;width:10%;height:4rpx}
  72%{top:calc(100% - 4rpx);left:-10%;width:10%;height:4rpx}
  73%{top:110%;left:0;width:4rpx;height:10%}
  100%{top:-10%;left:0;width:4rpx;height:10%}
}

