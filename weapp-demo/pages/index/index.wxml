<view class="app">
  <view class="top">
    <view>
      <view class="brand-sub">JIN RI SHANG SHANG QIAN</view>
      <view class="brand">今日上上签</view>
    </view>
    <view class="streak">
      <text class="streak-num">{{streak}}</text>
      <text class="streak-label">连续天</text>
    </view>
    <view wx:if="{{myTitle}}" class="my-title-badge">{{myTitle}}</view>
  </view>

  <view wx:if="{{tab === 'draw'}}" class="page" style="padding-bottom:80rpx">
    <view class="panel">
      <view class="title">摸一张<text>今日财运签</text></view>
      <view class="hint">微信小程序 Demo，验证抽卡、广告、牌册与漂流签。</view>
      <view class="luck-axis {{rolling ? 'rolling' : ''}}">
        <view class="axis-line">
          <view class="axis-mark" style="left: {{axisLeft}}%;"></view>
        </view>
        <view class="axis-labels">
          <text>平</text>
          <text>上</text>
          <text class="hot">上上</text>
          <text class="hot">大吉</text>
        </view>
      </view>
      <view class="pre-note">签位未定，翻开才知道。</view>
      <view class="quota">{{quotaText}}</view>
      <view class="deck {{current.grade === '大吉签' ? 'rare' : ''}} {{shareFlying ? 'share-card-flying' : ''}}">
        <view class="aura"></view>
        <view class="card {{cardClass}} {{current.grade === '大吉签' ? 'card-daji' : ''}} {{current.grade === '上上签' ? 'card-shangshang' : ''}} {{current.grade === '彩蛋签' ? 'card-egg draw-egg-' + current.theme : ''}}">
          <view class="card-sweep-wrap" wx:if="{{current.grade === '大吉签'}}">
            <view class="card-sweep"></view>
            <view class="card-glow-orbit"><view class="cg1"></view><view class="cg2"></view></view>
          </view>
          <view class="draw-egg-deco" wx:if="{{current.grade === '彩蛋签'}}">
            <view wx:if="{{current.theme === 'peach'}}">
              <view class="draw-egg-glow"></view><view class="draw-egg-crown"></view><view class="draw-egg-stem"></view>
            </view>
            <view wx:elif="{{current.theme === 'golden'}}">
              <view class="draw-egg-glow"></view><view class="draw-egg-body"></view>
            </view>
            <view wx:elif="{{current.theme === 'home'}}">
              <view class="draw-egg-moon"></view><view class="draw-egg-roof"></view><view class="draw-egg-wall"></view>
            </view>
            <view wx:elif="{{current.theme === 'travel'}}">
              <view class="draw-egg-haze"></view><view class="draw-egg-bg-mt"></view><view class="draw-egg-fg-mt"></view>
            </view>
          </view>
          <view class="rarity">{{current.grade || '今日签'}}</view>
          <view class="seal">
            <text>{{current.seal || '签'}}</text>
            <text class="seal-sub">今日</text>
          </view>
          <view class="kw">{{current.name || '未抽'}}</view>
          <view class="txt">{{current.text || '点击下方按钮，抽取今天的第一张上上签。'}}</view>
          <view class="pills">
            <view class="pill"><text>宜</text>{{current.do || '先看方向'}}</view>
            <view class="pill"><text>忌</text>{{current.avoid || '急着判断'}}</view>
          </view>
          <view class="micro"><text>微行动</text>{{current.action || '给今天留一个 3 分钟的小开局。'}}</view>
        </view>
      </view>
      <view class="btn primary-action" bindtap="onDraw">{{drawButtonText}}</view>
      <view wx:if="{{hasDrawn}}" class="actions">
        <view class="row">
          <view class="btn action-btn" bindtap="onVerify">今天真的有点准</view>
          <view class="btn sub action-btn" bindtap="onCollect">收入牌册</view>
        </view>
        <view class="row">
          <view class="btn sub action-btn" bindtap="onShareCard">生成比手气卡</view>
          <view wx:if="{{canTurn}}" class="btn sub action-btn" bindtap="onTurn">看广告转运</view>
        </view>
        <view class="btn sub full-action" bindtap="onBonus">看广告补充签</view>
        <view wx:if="{{current.type === 'negative'}}" class="btn danger full-action" bindtap="openDissolveInput">我已克服 / 我已解决</view>
      </view>
      <view wx:if="{{verifyShown}}" class="msg">
        <text>感谢收获</text>
        如果这张签今天真的帮你留住了一点好运，可以轻轻添一束好运火。
        <button class="btn mini" bindtap="onSupport">模拟添一束好运火</button>
      </view>
    </view>
  </view>

  <view wx:if="{{tab === 'album'}}" class="page" style="padding-bottom:80rpx">
    <view class="title">我的<text>好运牌册</text></view>
    <view class="hint">每种签各自样式统一，可多张并存。大吉签含专属动效。</view>
    <view class="album-v2">
      <block wx:for="{{albumDisplay}}" wx:key="id">
        <view wx:if="{{item.isGroupHeader}}" class="album-section-title">{{item.grade}} <text>{{item.collectedCount}}/{{item.totalCount}}</text></view>

        <view wx:elif="{{item.locked}}" class="album-card {{item.grade === '大吉签' ? 'ac-daji' : item.grade === '上上签' ? 'ac-shangshang' : item.grade === '上签' ? 'ac-shang' : 'ac-ping'}} ac-locked">
          <view class="ac-locked-mask">
            <view class="ac-locked-icon">?</view>
            <view class="ac-locked-text">尚未收集</view>
          </view>
        </view>

        <view wx:elif="{{item.grade === '大吉签'}}" class="album-card ac-daji">
          <view class="ac-glow-orbit"><view class="ac-g1"></view><view class="ac-g2"></view></view>
          <view class="ac-sweep"></view>
          <view class="ac-daji-texture">
            <view class="ac-flame-bar"><view class="afb1"></view><view class="afb2"></view><view class="afb3"></view></view>
            <view class="ac-star"><view class="asc"></view><view class="ash"></view><view class="asv"></view></view>
          </view>
          <view class="album-card-inner">
            <view class="ac-top"><view class="ac-grade">大吉签</view><view class="ac-seal">{{item.seal}}</view></view>
            <view class="ac-body"><view class="ac-name">{{item.name}}</view><view class="ac-text">{{item.text}}</view></view>
            <view class="ac-bottom"><view class="ac-action">{{item.action}}</view></view>
          </view>
          <view class="ac-bottom-deco"></view>
        </view>
        <view wx:elif="{{item.grade === '上上签'}}" class="album-card ac-shangshang">
          <view class="ac-ss-texture"><view class="ac-arc ac-arc1"></view><view class="ac-arc ac-arc2"></view><view class="ac-arc ac-arc3"></view></view>
          <view class="album-card-inner">
            <view class="ac-top"><view class="ac-grade">上上签</view><view class="ac-seal">{{item.seal}}</view></view>
            <view class="ac-body"><view class="ac-name">{{item.name}}</view><view class="ac-text">{{item.text}}</view></view>
            <view class="ac-bottom"><view class="ac-action">{{item.action}}</view></view>
          </view>
          <view class="ac-bottom-deco"></view>
        </view>
        <view wx:elif="{{item.grade === '上签'}}" class="album-card ac-shang">
          <view class="album-card-inner">
            <view class="ac-top"><view class="ac-grade">上签</view><view class="ac-seal">{{item.seal}}</view></view>
            <view class="ac-body"><view class="ac-name">{{item.name}}</view><view class="ac-text">{{item.text}}</view></view>
            <view class="ac-bottom"><view class="ac-action">{{item.action}}</view></view>
          </view>
          <view class="ac-bottom-deco"></view>
        </view>
        <view wx:elif="{{item.grade === '平签'}}" class="album-card ac-ping">
          <view class="album-card-inner">
            <view class="ac-top"><view class="ac-grade">平签</view><view class="ac-seal">{{item.seal}}</view></view>
            <view class="ac-body"><view class="ac-name">{{item.name}}</view><view class="ac-text">{{item.text}}</view></view>
            <view class="ac-bottom"><view class="ac-action">{{item.action}}</view></view>
          </view>
          <view class="ac-bottom-deco"></view>
        </view>
        <view wx:elif="{{item.grade === '彩蛋签'}}" class="album-card ac-egg ac-egg-{{item.theme}}">
          <view class="egg-deco">
            <block wx:if="{{item.theme === 'peach'}}">
              <view class="egg-glow"></view>
              <view class="egg-crown"></view>
              <view class="egg-crown2"></view>
              <view class="egg-stem"></view>
              <view class="egg-petal"></view>
              <view class="egg-petal"></view>
              <view class="egg-petal"></view>
            </block>
            <block wx:elif="{{item.theme === 'golden'}}">
              <view class="egg-glow"></view>
              <view class="egg-cap t"></view>
              <view class="egg-body"></view>
              <view class="egg-lines"><view></view><view></view><view></view></view>
              <view class="egg-cap b"></view>
              <view class="egg-seal-stamp"></view>
            </block>
            <block wx:elif="{{item.theme === 'home'}}">
              <view class="egg-moon"></view>
              <view class="egg-roof"></view>
              <view class="egg-puff"></view>
              <view class="egg-puff"></view>
              <view class="egg-wall"></view>
              <view class="egg-arch"></view>
              <view class="egg-lit-win"></view>
            </block>
            <block wx:elif="{{item.theme === 'travel'}}">
              <view class="egg-haze"></view>
              <view class="egg-bg-mt"></view>
              <view class="egg-fg-mt"></view>
              <view class="egg-peak"></view>
              <view class="egg-flag-stick"></view>
              <view class="egg-flag-cloth"></view>
            </block>
          </view>
          <view class="album-card-inner">
            <view class="ac-top"><view class="ac-grade">彩蛋签</view><view class="ac-seal">{{item.seal}}</view></view>
            <view class="ac-body"><view class="ac-name">{{item.name}}</view><view class="ac-text">{{item.text}}</view></view>
            <view class="ac-bottom"><view class="ac-action">{{item.action}}</view></view>
          </view>
          <view class="ac-bottom-deco"></view>
        </view>
      </block>
    </view>
    <view class="album-stats">
      <view class="album-stat"><b>{{albumTotal}}</b><span>已收集</span></view>
      <view class="album-stat"><b>{{albumDajiCount}}</b><span>大吉签</span></view>
      <view class="album-stat"><b>{{albumSSCount}}</b><span>上上签</span></view>
      <view class="album-stat"><b>{{albumSCount}}</b><span>上签</span></view>
      <view class="album-stat egg"><b>{{albumEggCount}}</b><span>彩蛋签</span></view>
    </view>
  </view>

  <view wx:if="{{tab === 'drift'}}" class="page" style="position:relative;padding-bottom:80rpx">
    <view class="title">漂流<text>好运签</text></view>
    <view class="hint">把签匿名或实名送给陌生人或好友，附上一句话。</view>
    <view class="drift-tabs">
      <view class="drift-tab {{driftSubTab === 'received' ? 'on' : ''}}" bindtap="switchDriftTab" data-sub="received">收到的签</view>
      <view class="drift-tab {{driftSubTab === 'sent' ? 'on' : ''}}" bindtap="switchDriftTab" data-sub="sent">我送出的</view>
    </view>
    <view class="drift-list">
      <view wx:for="{{driftList}}" wx:key="id" class="drift-item">
        <view class="drift-meta">
          <view class="drift-avatar">{{item.avatar}}</view>
          <view class="drift-name">{{item.name}}</view>
          <view class="drift-tag">{{item.grade}}</view>
        </view>
        <view class="drift-quote">{{item.quote}}</view>
        <view class="drift-from">来自 · {{item.from}}</view>
        <view class="drift-actions">
          <view class="drift-btn" bindtap="onDriftThank">感谢</view>
          <view class="drift-btn primary" bindtap="onDriftReply" data-id="{{item.id}}">{{item.canAddFriend ? '加为好友' : '回赠一张签'}}</view>
        </view>
      </view>
    </view>
    <view wx:if="{{friendModalVisible}}" class="drift-modal-overlay" bindtap="closeFriendModal">
      <view class="drift-modal" catchtap="preventBubble">
        <view class="drift-modal-avatar">{{friendModal.avatar}}</view>
        <view class="drift-modal-title">{{friendModal.name}} 想加你为好友</view>
        <view class="drift-modal-sub">来自漂流签 · {{friendModal.grade}}</view>
        <view class="drift-modal-note">{{friendModal.quote}}</view>
        <view class="drift-modal-actions">
          <view class="drift-modal-btn" bindtap="closeFriendModal">暂不考虑</view>
          <view class="drift-modal-btn primary" bindtap="acceptFriend">同意添加</view>
        </view>
      </view>
    </view>
    <view class="drift-send-bar">
      <view class="drift-send-icon">+</view>
      <view class="drift-send-info"><b>送出一张好运签</b><text>把今天的签装进漂流瓶</text></view>
      <view class="drift-send-btn" bindtap="onSendDrift">去送出</view>
    </view>
  </view>

  <view wx:if="{{tab === 'friends'}}" class="page" style="padding-bottom:80rpx">
    <view class="title">好友<text>比手气</text></view>
    <view class="hint">今日累计好运值 {{todayScore}} 分（已抽{{todayDrawCount}}张），排名第{{myRank}}名。{{shareReceived ? '比手气卡已送达。' : '点击"生成比手气卡"可送好友榜。'}}</view>
    <view class="friend-list">
      <view wx:for="{{friends}}" wx:key="name" class="friend {{item.isMe ? 'friend-me' : ''}}">
        <view class="rank">{{index + 1}}</view>
        <view class="avatar"></view>
        <view class="friend-meta">
          <view>{{item.name}}{{item.isMe ? '（我）' : ''}}<text wx:if="{{item.title}}" class="friend-title"> · {{item.title}}</text></view>
          <text>{{item.grade}} · {{item.card}} · 好运值 {{item.score}}</text>
        </view>
      </view>
    </view>
    <view class="panel pool-panel">
      <view class="pool">
        <view></view><view></view><view></view><view></view><view></view>
      </view>
      <view class="hint center">今天这组人的火很旺。适合一起推进一件拖了很久的小事。</view>
    </view>
  </view>

  <view wx:if="{{tab === 'me'}}" class="page" style="padding-bottom:80rpx">
    <view class="title">今日<text>分享卡</text></view>
    <view class="my-titles-section">
      <view class="my-titles-title">我的称号 <text class="my-titles-hint">（点击称号可设置优先展示）</text></view>
      <view class="my-titles-list">
        <view wx:if="{{myTitles.length === 0}}" class="my-titles-empty">集齐同一等级全部签卡即可获得称号</view>
        <block wx:for="{{myTitles}}" wx:key="*this">
          <view class="my-title-tag {{item === preferredTitle ? 'active' : ''}}" bindtap="selectPreferredTitle" data-title="{{item}}">
            <text wx:if="{{item === preferredTitle}}" class="title-crown">👑</text>{{item}}
          </view>
        </block>
      </view>
    </view>
    <view class="share-card">
      <view class="share-k">JRSSQ · SHARE CARD</view>
      <view class="share-title">我抽到「{{current.name || '今日上上签'}}」</view>
      <view class="share-text">来比比你今天的手气。好友好运聚在一起，会生成一段群体鼓励。</view>
    </view>
    <button class="btn" bindtap="onCopy">复制分享文案</button>
    <view class="survey-entry" bindtap="openSurvey">
      <view class="survey-entry-icon">📋</view>
      <view class="survey-entry-info"><b>填写反馈问卷</b><text>完成可获得1次免费抽签机会</text></view>
      <view class="survey-entry-arrow">›</view>
    </view>
    <button class="btn sub reset" bindtap="onReset">重置 Demo</button>
  </view>



  <view wx:if="{{surveyVisible}}" class="survey-overlay" bindtap="closeSurvey">
    <view class="survey-card" catchtap="preventBubble">
      <view class="survey-header">
        <view class="survey-title">用户反馈问卷</view>
        <view class="survey-sub">完成问卷可获得1次免费抽签机会</view>
      </view>

      <view class="survey-q">
        <view class="survey-q-title">1. 你最喜欢哪个功能？</view>
        <view class="survey-opts">
          <view class="survey-opt {{surveyAnswers.q1 === 'draw' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q1" data-val="draw">每日抽签</view>
          <view class="survey-opt {{surveyAnswers.q1 === 'album' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q1" data-val="album">牌册收集</view>
          <view class="survey-opt {{surveyAnswers.q1 === 'drift' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q1" data-val="drift">漂流签社交</view>
          <view class="survey-opt {{surveyAnswers.q1 === 'friend' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q1" data-val="friend">好友比手气</view>
        </view>
      </view>

      <view class="survey-q">
        <view class="survey-q-title">2. 你觉得签的建议对你有帮助吗？</view>
        <view class="survey-opts">
          <view class="survey-opt {{surveyAnswers.q2 === 'very' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q2" data-val="very">非常有帮助</view>
          <view class="survey-opt {{surveyAnswers.q2 === 'somewhat' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q2" data-val="somewhat">有一点帮助</view>
          <view class="survey-opt {{surveyAnswers.q2 === 'neutral' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q2" data-val="neutral">一般般</view>
          <view class="survey-opt {{surveyAnswers.q2 === 'no' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q2" data-val="no">没什么帮助</view>
        </view>
      </view>

      <view class="survey-q">
        <view class="survey-q-title">3. 你希望增加什么功能？</view>
        <view class="survey-opts">
          <view class="survey-opt {{surveyAnswers.q3 === 'more' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q3" data-val="more">更多签卡内容</view>
          <view class="survey-opt {{surveyAnswers.q3 === 'share' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q3" data-val="share">分享海报更好看</view>
          <view class="survey-opt {{surveyAnswers.q3 === 'social' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q3" data-val="social">更多社交互动</view>
        </view>
      </view>

      <view class="survey-q">
        <view class="survey-q-title">4. 你会推荐给朋友吗？</view>
        <view class="survey-opts">
          <view class="survey-opt {{surveyAnswers.q4 === 'yes' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q4" data-val="yes">一定会</view>
          <view class="survey-opt {{surveyAnswers.q4 === 'maybe' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q4" data-val="maybe">可能会</view>
          <view class="survey-opt {{surveyAnswers.q4 === 'no' ? 'on' : ''}}" bindtap="onSurveyPick" data-q="q4" data-val="no">不会</view>
        </view>
      </view>

      <view class="survey-q">
        <view class="survey-q-title">5. 自由留言（可选，50字以内）</view>
        <input class="survey-input" placeholder="写下你想说的话..." maxlength="50" bindinput="onSurveyFeedback" value="{{surveyFeedback}}" />
        <view class="survey-char-count">{{surveyFeedback.length}}/20</view>
      </view>

      <view class="survey-submit" bindtap="submitSurvey">提交并领取奖励</view>
    </view>
  </view>

  <view wx:if="{{dissolveInputVisible}}" class="dissolve-overlay" bindtap="closeDissolveInput">
    <view class="dissolve-card" catchtap="preventBubble">
      <view class="dissolve-title">写下你想对这张签说的话</view>
      <view class="dissolve-sub">输入后这张签将合并消失，转化为正向能量</view>
      <input class="dissolve-input" placeholder="例如：我已克服" bindinput="onDissolveInput" value="{{dissolveInput}}" />
      <view class="dissolve-actions">
        <view class="dissolve-btn" bindtap="closeDissolveInput">再想想</view>
        <view class="dissolve-btn primary" bindtap="confirmDissolve">确认消除</view>
      </view>
    </view>
  </view>

  <view wx:if="{{supportVisible}}" class="support-overlay" bindtap="closeSupport">
    <view class="support-card" catchtap="preventBubble">
      <view class="support-title">添一束好运火</view>
      <view class="support-sub">感谢这份签今天帮到了你，点亮一束火为好运加油。</view>
      <view class="support-amounts">
        <view class="support-amount" bindtap="confirmSupport" data-amount="1">
          <view class="sa-val">¥1</view>
          <view class="sa-label">小火苗</view>
        </view>
        <view class="support-amount sa-pop" bindtap="confirmSupport" data-amount="3">
          <view class="sa-val">¥3</view>
          <view class="sa-label">旺火</view>
        </view>
        <view class="support-amount" bindtap="confirmSupport" data-amount="5">
          <view class="sa-val">¥5</view>
          <view class="sa-label">大火</view>
        </view>
      </view>
      <view class="support-hint">这是自愿感谢，不影响签的内容</view>
    </view>
  </view>

  <view wx:if="{{adVisible}}" class="ad-overlay">
    <view class="ad-card">
      <view class="ad-tag">SIMULATED AD · 2.6S</view>
      <view class="ad-title">好运加载中</view>
      <view class="ad-copy">{{adCopy}}</view>
      <view class="ad-progress"><view></view></view>
      <view class="ad-count">广告结束后继续</view>
    </view>
  </view>

  <view class="tabs">
    <view class="tab {{tab === 'draw' ? 'on' : ''}}" data-tab="draw" bindtap="switchTab">签<text>抽签</text></view>
    <view class="tab {{tab === 'album' ? 'on' : ''}}" data-tab="album" bindtap="switchTab">册<text>牌册</text></view>
    <view class="tab {{tab === 'drift' ? 'on' : ''}}" data-tab="drift" bindtap="switchTab">漂<text>漂流</text></view>
    <view class="tab {{tab === 'friends' ? 'on' : ''}}" data-tab="friends" bindtap="switchTab">火<text>好友</text></view>
    <view class="tab {{tab === 'me' ? 'on' : ''}}" data-tab="me" bindtap="switchTab">我<text>分享</text></view>
  </view>
